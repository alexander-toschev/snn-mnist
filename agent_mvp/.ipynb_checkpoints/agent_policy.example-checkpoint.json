{
  "project_name": "snn-mnist",
  "random_seed": 42,
  "mutation_changes": 2,
  "mutate_best_probability": 0.7,
  "base_overrides": {
    "device": "cuda",
    "N": 60000,
    "warmup_N": 10000,
    "log_every": 50,
    "seed": 42,
    "encoder_out_format": "auto"
  },
  "templates": {
    "baseline_poisson": {
      "time": 200,
      "n_hidden": 100,
      "encoder": "poisson",
      "poisson_rate_scale": 0.011,
      "encoder_rate_boost": 3.0,
      "inhib_strength": 0.705,
      "thresh_init": 0.38,
      "top_k": 0,
      "latency_x_min": 0.05
    },
    "latency_filtered": {
      "time": 200,
      "n_hidden": 100,
      "encoder": "latency",
      "poisson_rate_scale": 0.011,
      "encoder_rate_boost": 1.0,
      "inhib_strength": 0.705,
      "thresh_init": 0.38,
      "top_k": 0,
      "latency_x_min": 0.05
    },
    "poisson_dense_200": {
      "time": 200,
      "n_hidden": 200,
      "encoder": "poisson",
      "poisson_rate_scale": 0.011,
      "encoder_rate_boost": 5.0,
      "inhib_strength": 0.705,
      "thresh_init": 0.38,
      "top_k": 3,
      "latency_x_min": 0.05
    }
  },
  "seed_queue": [
    "baseline_poisson",
    "latency_filtered",
    "poisson_dense_200"
  ],
  "search_space": {
    "time": [100, 150, 200, 300],
    "n_hidden": [100, 200, 400],
    "encoder": ["poisson", "latency"],
    "poisson_rate_scale": [0.008, 0.011, 0.015],
    "encoder_rate_boost": [1.0, 3.0, 5.0, 5.5],
    "latency_x_min": [0.03, 0.05, 0.07, 0.1],
    "inhib_strength": [0.3, 0.5, 0.705, 0.9],
    "thresh_init": [0.25, 0.38, 0.5],
    "top_k": [0, 1, 3]
  },
  "score_weights": {
    "best_readout_acc": 1.0,
    "energy_proxy_per_sample": -0.0003,
    "synops_per_sample": -0.00002,
    "spikes_per_sample": 0.001
  },
  "guards": {
    "max_failures": 3
  },
  "runner": {
    "n_calib": 2000,
    "n_train_counts": 60000,
    "n_test_counts": 10000,
    "quiet": false,
    "no_progress": false,
    "skip_label_map": false,
    "skip_eval": false
  }
}
